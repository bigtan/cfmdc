# CTP Market Data Configuration (TOML)

# Front server configuration
# Support single server table or multiple server tables (array of tables)
# When using multiple servers, the application will try them in order if connection fails

# Example 1: Single server (backward compatible)
# [Front]
# MD_Url = "tcp://180.168.146.187:10131"
# TD_Url = "tcp://180.168.146.187:10130"
# BrokerID = "9999"
# UserID = "your_user_id"
# Password = "your_password"
# UserProductInfo = "your_product_info"
# AuthCode = "your_auth_code"
# AppID = "your_app_id"

# Example 2: Multiple servers (recommended for production)
[[Front]]
MD_Url = "tcp://180.168.146.187:10131" # Primary market data front
TD_Url = "tcp://180.168.146.187:10130" # Primary trading front
BrokerID = "9999"
UserID = "your_user_id"
Password = "your_password"
UserProductInfo = "your_product_info"
AuthCode = "your_auth_code"
AppID = "your_app_id"

[[Front]]
MD_Url = "tcp://180.168.146.187:10211" # Backup market data front
TD_Url = "tcp://180.168.146.187:10201" # Backup trading front
BrokerID = "9999"
UserID = "your_user_id"
Password = "your_password"
UserProductInfo = "your_product_info"
AuthCode = "your_auth_code"
AppID = "your_app_id"

[History]
StorageMode = "Parquet" # Storage format: CSV, Parquet, or Hybrid

# Storage paths for different formats (enabled based on StorageMode)
# Placeholders supported:
#   {tradingday} - Trading day in YYYYMMDD format
#   {year}       - Year in YYYY format
#   {month}      - Month in MM format
#   {day}        - Day in DD format
CSVPath = "./data/csv/{tradingday}" # Used when StorageMode is CSV or Hybrid
ParquetPath = "./data/parquet/{tradingday}" # Used when StorageMode is Parquet or Hybrid
ParquetRowGroupSize = 100000 # Lower values reduce flush tail latency; valid range: 1-1000000

# Examples of path patterns:
# - "./data/csv/{tradingday}"           -> ./data/csv/20231011
# - "./data/{year}/{month}/csv"         -> ./data/2023/10/csv
# - "./data/{year}/csv/{tradingday}"    -> ./data/2023/csv/20231011

[Application]
InitTimeout = 60 # Initialization timeout in seconds (default: 60)
FlowPath = "./flow" # CTP API flow file directory (default: "./flow")
SubList = "null" # Global instrument list: "null" = all, or "rb2505|IC2501"

# Worker thread CPU affinity (Thread Pinning)
# This settings binds the high-performance async writer thread to a specific CPU core.
# Options:
#   -1      : Disable affinity (let OS decide, default)
#   "auto"  : Automatically select the last available core (skips core 0 to avoid interrupts)
#   0, 1... : Manually specify a core index
#
# Recommendations:
#   - For VPS: Use "auto" to avoid core 0 which usually handles network interrupts.
#   - For Physical Machines: Pin to a dedicated isolated core for lowest latency.
WorkerThreadCore = "auto"
